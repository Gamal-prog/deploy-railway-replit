SECRET_KEY=change-me
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Optional. If omitted, Django uses local SQLite.
# Railway/other PaaS usually provide this automatically for Postgres.
DATABASE_URL=

# Alternative Railway-style Postgres variables.
PGDATABASE=
PGUSER=
PGPASSWORD=
PGHOST=
PGPORT=5432

# Optional: create admin user automatically during deploy.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=

# Bunny Stream. Library id is hardcoded in settings as 703470.
BUNNY_STREAM_API_KEY=
BUNNY_API_KEY=
BUNNY_STREAM_API_TIMEOUT=8

# Optional. Use only if Bunny Stream > Security > Embed View Token Authentication is enabled.
BUNNY_STREAM_EMBED_TOKEN_KEY=
BUNNY_STREAM_EMBED_TOKEN_TTL=3600
